# Restore: move barbara back to ou=users from ou=services
# Run with: ldapmodify -x -y ~/.ldappasswd -f ch3-test-07-restore.ldif
# Verify with:
#   ldapsearch -x -y ~/.ldappasswd "(uid=barbara)" ou dn
dn: uid=barbara,ou=services,dc=marsel,dc=is
changetype: modrdn
newrdn: uid=barbara
deleteoldrdn: 1
newsuperior: ou=users,dc=marsel,dc=is
